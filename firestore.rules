rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helpers ──────────────────────────────────────────────
    function isAuth() { return request.auth != null; }
    function isOwner(uid) { return isAuth() && request.auth.uid == uid; }

    // ── Users ────────────────────────────────────────────────
    match /users/{uid} {
      allow read: if isAuth();
      allow create: if isOwner(uid);
      allow update: if isOwner(uid);
    }

    // ── Matches ──────────────────────────────────────────────
    match /matches/{matchId} {
      allow read: if isAuth();
      allow create: if isAuth();
      allow update: if isAuth() && (
        request.auth.uid == resource.data.organizerId ||
        // rejoindre / quitter
        request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly(['pendingIds', 'playerIds'])
      );
      allow delete: if false;
    }

    // ── Match Reviews ────────────────────────────────────────
    match /matchReviews/{reviewId} {
      allow read: if isAuth();
      allow create: if isAuth() && request.auth.uid == request.resource.data.reviewerId;
      allow update, delete: if false;
    }

    // ── Tournaments ──────────────────────────────────────────
    match /tournaments/{tournamentId} {
      allow read: if isAuth();
      allow write: if false; // Gérés par les admins uniquement
    }

    // ── Tournament Registrations ─────────────────────────────
    match /tournamentRegistrations/{regId} {
      allow read: if isAuth() && request.auth.uid == resource.data.userId;
      allow create: if isAuth() && request.auth.uid == request.resource.data.userId;
      allow update, delete: if false;
    }

    // ── Coaches ──────────────────────────────────────────────
    match /coaches/{coachId} {
      allow read: if isAuth();
      allow write: if false;
    }

    // ── Credit Transactions ──────────────────────────────────
    match /creditTransactions/{txId} {
      allow read: if isAuth() && request.auth.uid == resource.data.userId;
      allow write: if false; // Gérés uniquement par les Cloud Functions
    }

    // ── User Stats ───────────────────────────────────────────
    match /userStats/{uid} {
      allow read: if isOwner(uid);
      allow write: if false; // Gérés uniquement par les Cloud Functions
    }

    // ── Rankings (classement public) ─────────────────────────
    match /rankings/{uid} {
      allow read: if isAuth(); // visible par tous les joueurs connectés
      allow write: if false;   // Gérés uniquement par les Cloud Functions
    }

    // ── Clubs partenaires ────────────────────────────────────
    match /clubs/{clubId} {
      allow read: if isAuth();
      allow write: if false; // Gérés par les admins uniquement

      match /courts/{courtId} {
        allow read: if isAuth();
        allow write: if false;
      }
    }

    // ── Réservations terrains ────────────────────────────────
    match /reservations/{resId} {
      allow read: if isAuth() && request.auth.uid == resource.data.userId;
      // Création et mise à jour uniquement via Cloud Function (bookCourtSlot)
      allow write: if false;
    }

    // ── Receipts IAP (idempotence) ───────────────────────────
    match /iapReceipts/{receiptId} {
      allow read, write: if false; // Cloud Functions uniquement
    }

    // ── Disponibilité joueurs (matchmaking) ──────────────────
    match /userAvailability/{uid} {
      allow read: if isAuth();
      allow write: if isOwner(uid);
    }

    // ── Invitations de match ─────────────────────────────────
    match /matchInvitations/{invId} {
      allow read: if isAuth() && (
        request.auth.uid == resource.data.fromUid ||
        request.auth.uid == resource.data.toUid
      );
      // Créées uniquement via Cloud Function (invitePlayerToMatch)
      allow write: if false;
    }

    // ── Conversations & Messages ──────────────────────────────
    function isParticipant(data) {
      return isAuth() && request.auth.uid in data.participantIds;
    }

    match /conversations/{convId} {
      allow read:   if isParticipant(resource.data);
      allow create: if isAuth() &&
                       request.auth.uid in request.resource.data.participantIds &&
                       request.resource.data.participantIds.size() >= 2;
      allow update: if isParticipant(resource.data);
      allow delete: if false;

      match /messages/{msgId} {
        allow read: if isParticipant(
          get(/databases/$(database)/documents/conversations/$(convId)).data
        );
        allow create: if isAuth() &&
          request.auth.uid in
            get(/databases/$(database)/documents/conversations/$(convId)).data.participantIds &&
          request.auth.uid == request.resource.data.senderId;
        allow update, delete: if false;
      }
    }

    // ── Candidatures clubs (site web public) ─────────────────
    match /clubApplications/{appId} {
      allow read:          if false; // Admins uniquement
      allow create:        if true;  // Formulaire public
      allow update, delete: if false;
    }
  }
}
